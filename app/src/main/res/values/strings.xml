    <string name="onboarding_step_notifications_title">Notifications</string>
    <string name="onboarding_step_notifications_why">We use notifications to warn you about suspicious calls and SMS in real time.</string>
    <string name="onboarding_step_phone_title">Phone</string>
    <string name="onboarding_step_phone_why">We read the phone state so we can analyze incoming calls without recording them.</string>
    <string name="onboarding_step_call_log_title">Call log</string>
    <string name="onboarding_step_call_log_why">We read the call log so we can correlate recent calls into a single risk campaign.</string>
    <string name="onboarding_step_sms_title">SMS</string>
    <string name="onboarding_step_sms_why">We read SMS locally so we can flag fraud patterns. Bodies are stored hashed and truncated.</string>
