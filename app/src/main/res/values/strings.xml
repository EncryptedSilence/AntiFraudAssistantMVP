    <string name="onboarding_step_full_screen_why">Lets us show a full-screen warning while you are on a call.</string>
    <string name="onboarding_step_overlay_title">Overlay banner</string>
    <string name="onboarding_step_overlay_why">Lets us show a thin warning banner on top of banking apps.</string>
    <string name="onboarding_step_battery_title">Battery exemption</string>
    <string name="onboarding_step_battery_why">Exempting the app from battery optimization keeps the call-observer service alive.</string>
