<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- §4.2.1 runtime permissions -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />

    <!-- §17.0.3 + §4.2.1 — passive transparency notification + foreground service of type phoneCall -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />
    <!-- Android 14+ requires this or default-Dialer role for a phoneCall foreground service. -->
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />

    <!-- §22 Stage 3 — battery-optimization-exemption prompt -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application>
        <service
            android:name=".CallObserverService"
            android:exported="false"
            android:foregroundServiceType="phoneCall" />
    </application>
</manifest>
